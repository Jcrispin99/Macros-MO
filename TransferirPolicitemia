
Sub TransferirPolicitemia()                                                                                                                                                                                                                                                                  
      Dim wsOri As Worksheet, wsDes As Worksheet                                                                                                                                                                                                                                             
      Dim i As Long, filaOri As Long, filaDes As Long                                                                                                                                                                                                                                          
      Dim dni As String                                                                                                                                                                                                                                                                        
      Dim cols As Variant, slot As Long                                                                                                                                                                                                                                                        
      Dim filaExistente As Variant                                                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                                                               
      ' Verificar hojas (flexible con espacios y mayusculas)                                                                                                                                                                                                                                   
      Set wsOri = HojaPorNombre(ThisWorkbook, "MATRIZ GENERAL")                                                                                                                                                                                                                                
      Set wsDes = HojaPorNombre(ThisWorkbook, "ERITROCITOSIS")                                                                                                                                                                                                                                 
      If wsOri Is Nothing Then MsgBox "Hoja 'MATRIZ GENERAL' no encontrada. Revisa el nombre exacto de la pestaña.", vbCritical: Exit Sub                                                                                                                                                      
      If wsDes Is Nothing Then MsgBox "Hoja 'ERITROCITOSIS' no encontrada. Revisa el nombre exacto de la pestaña.", vbCritical: Exit Sub                                                                                                                                                       
                                                                                                                                                                                                                                                                                               
      Application.ScreenUpdating = False                                                                                                                                                                                                                                                       
      Application.Calculation = xlCalculationManual                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                               
      cols = Array("AA", "AG", "AM", "AS", "AY", "BE", "BK", "BQ", "BW")                                                                                                                                                                                                                       
   
      filaOri = wsOri.Cells(wsOri.Rows.Count, "H").End(xlUp).Row                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                                                             
      For i = 4 To filaOri                                                                                                                                                                                                                                                                     
          dni = LeerCeldaSegura(wsOri, i, "H")                                                                                                                                                                                                                                               

          If Len(dni) = 0 Then GoTo Sig                                                                                                                                                                                                                                                        
          If Not IsNumeric(dni) Then GoTo Sig    ' ignora si no es numero valido                                                                                                                                                                                                               
          If Len(LeerCeldaSegura(wsOri, i, "CR")) = 0 Then GoTo Sig                                                                                                                                                                                                                            

                                                                                                                                                                                                                                                                                               
          filaExistente = BuscarDni(wsDes, dni)                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                               
          If IsEmpty(filaExistente) Then                                                                                                                                                                                                                                                       
              ' DNI nuevo: agregar fila
              filaDes = wsDes.Cells(wsDes.Rows.Count, "H").End(xlUp).Row + 1                                                                                                                                                                                                                   
              If filaDes < 2 Then filaDes = 2                                                                                                                                                                                                                                                
              wsDes.Cells(filaDes, "E").Value = wsOri.Cells(i, "E").Value                                                                                                                                                                                                                      
              wsDes.Cells(filaDes, "H").Value = CDbl(dni)                                                                                                                                                                                                                                      
              slot = 0                                                                                                                                                                                                                                                                         
  Private Function LeerCeldaSegura(ws As Worksheet, fila As Long, col As String) As String                                                                                                                                                                                                     
      Dim v As Variant
      On Error Resume Next                                                                                                                                                                                                                                                                     
      v = ws.Cells(fila, col).Value                                                                                                                                                                                                                                                          
      On Error GoTo 0
      If IsError(v) Then                                                                                                                                                                                                                                                                       
          LeerCeldaSegura = ""
      Else                                                                                                                                                                                                                                                                                     
          LeerCeldaSegura = Trim(CStr(v & ""))                                                                                                                                                                                                                                               
      End If                                                                                                                                                                                                                                                                                   

  End Function
                                                                                                                                                                                                                                                                                               
  Private Function BuscarDni(ws As Worksheet, dni As String) As Variant                                                                                                                                                                                                                      
      Dim ult As Long, k As Long, val As String

      ult = ws.Cells(ws.Rows.Count, "H").End(xlUp).Row                                                                                                                                                                                                                                         
      For k = 2 To ult
          val = LeerCeldaSegura(ws, k, "H")                                                                                                                                                                                                                                                    
          If Len(val) > 0 And IsNumeric(val) Then                                                                                                                                                                                                                                              
              If val = dni Then

                  BuscarDni = k                                                                                                                                                                                                                                                                
                  Exit Function                                                                                                                                                                                                                                                              
              End If                                                                                                                                                                                                                                                                           
          End If                                                                                                                                                                                                                                                                             
      Next k
      BuscarDni = Empty
  End Function

  Private Function SiguienteSlot(ws As Worksheet, fila As Long, cols As Variant) As Long                                                                                                                                                                                                       
      Dim s As Long, c As Long, val As String

      For s = 0 To 8                                                                                                                                                                                                                                                                           
          c = ws.Range(cols(s) & "1").Column                                                                                                                                                                                                                                                   
          val = ""
          If Not IsError(ws.Cells(fila, c).Value) Then                                                                                                                                                                                                                                         
              val = Trim(CStr(ws.Cells(fila, c).Value & ""))                                                                                                                                                                                                                                 
          End If                                                                                                                                                                                                                                                                               
          If Len(val) = 0 Then

              SiguienteSlot = s                                                                                                                                                                                                                                                                
              Exit Function                                                                                                                                                                                                                                                                    
          End If
      Next s                                                                                                                                                                                                                                                                                   
      SiguienteSlot = -1                                                                                                                                                                                                                                                                     
  End Function

  Private Sub EscribirBloque(wsDes As Worksheet, filaDes As Long, colIni As String, wsOri As Worksheet, filaOri As Long)                                                                                                                                                                       
      Dim c As Long
      c = wsDes.Range(colIni & "1").Column                                                                                                                                                                                                                                                     
      wsDes.Cells(filaDes, c + 0).Value = wsOri.Cells(filaOri, "D").Value    ' Fecha                                                                                                                                                                                                         
      wsDes.Cells(filaDes, c + 1).Value = wsOri.Cells(filaOri, "CR").Value   ' Hemoglobina                                                                                                                                                                                                     
      wsDes.Cells(filaDes, c + 2).Value = wsOri.Cells(filaOri, "CS").Value   ' Hematocrito                                                                                                                                                                                                     
      wsDes.Cells(filaDes, c + 4).Value = wsOri.Cells(filaOri, "AQ").Value   ' Tipo examen                                                                                                                                                                                                     
  End Sub                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                               
  Sub MostrarHojas()                                                                                                                                                                                                                                                                           
      Dim ws As Worksheet, txt As String                                                                                                                                                                                                                                                     
      For Each ws In ThisWorkbook.Sheets
          txt = txt & "[" & ws.Name & "]" & vbCrLf                                                                                                                                                                                                                                             
      Next ws
      MsgBox txt                                                                                                                                                                                                                                                                               
  End Sub   
