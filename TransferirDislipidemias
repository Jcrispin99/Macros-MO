  Sub TransferirDislipidemias()                                                                                                   
      Dim wsOri As Worksheet, wsDes As Worksheet                                                                                  
      Dim ultOri As Long, ultDes As Long                                                                                          
      Dim datosOri As Variant, dnisDes As Variant                                                                                 
      Dim mapaDes As Collection                                                                                                 
      Dim i As Long, k As Long, n As Long                                                                                         
      Dim dni As String, dniNorm As String                                                                                        
      Dim filaDes As Long, colFecha As Long, slotLibre As Long
      Dim transferidos As Long, nuevos As Long, sinDislip As Long, yaLlenos As Long                                               
      Dim val As Variant, dniVal As Variant, cv As Variant                                                                        
      Dim t0 As Double
                                                                                                                                  
      ' Índices dentro del array datosOri (rango lee desde D, índice 1 = D)                                                     
      Const cD As Long = 1     ' D  - Fecha de Carga                                                                              
      Const cH As Long = 5     ' H  - DNI                                                                                         
      Const cCF As Long = 81   ' CF - COLESTEROL TOTAL                                                                            
      Const cCG As Long = 82   ' CG - HDL                                                                                         
      Const cCH As Long = 83   ' CH - LDL                                                                                         
      Const cCI As Long = 84   ' CI - VLDL                                                                                      
      Const cCJ As Long = 85   ' CJ - TRIGLICERIDOS                                                                               
                                                                                                                                
      Set wsOri = HojaPorNombre_Dis(ThisWorkbook, "MATRIZ GENERAL")                                                               
      If wsOri Is Nothing Then Set wsOri = HojaPorNombre_Dis(ThisWorkbook, "REGISTRO MEDIWEB")                                  
      Set wsDes = HojaPorNombre_Dis(ThisWorkbook, "DISLIPIDEMIAS")                                                                
      If wsOri Is Nothing Then MsgBox "Hoja origen no encontrada.", vbCritical: Exit Sub                                          
      If wsDes Is Nothing Then MsgBox "DISLIPIDEMIAS no encontrada.", vbCritical: Exit Sub                                        
                                                                                                                                  
      Application.ScreenUpdating = False                                                                                        
      Application.Calculation = xlCalculationManual                                                                               
      Application.EnableEvents = False                                                                                            
      t0 = Timer
                                                                                                                                  
      ultOri = wsOri.Cells(wsOri.Rows.Count, "H").End(xlUp).Row                                                                   
      ultDes = wsDes.Cells(wsDes.Rows.Count, "H").End(xlUp).Row
      If ultOri < 4 Then GoTo Fin                                                                                                 
      If ultDes < 2 Then ultDes = 2                                                                                               
  
      ' --- 1) Mapa DNI -> fila destino (lee desde H2 para garantizar array; H2 es header) ---                                    
      Set mapaDes = New Collection                                                                                              
      If ultDes >= 3 Then                                                                                                         
          dnisDes = wsDes.Range("H2:H" & ultDes).Value                                                                          
          For k = 2 To UBound(dnisDes, 1)   ' k=1 es header en H2                                                                 
              val = dnisDes(k, 1)                                                                                                 
              If Not IsError(val) Then
                  If IsNumeric(val) And Len(Trim(CStr(val & ""))) > 0 Then                                                        
                      On Error Resume Next                                                                                        
                      mapaDes.Add k + 1, CStr(CDbl(val))   ' fila real = k+1 (k=2 → fila 3)
                      On Error GoTo 0                                                                                             
                  End If                                                                                                        
              End If                                                                                                              
          Next k                                                                                                                
      End If
                                                                                                                                  
      ' --- 2) Bulk read origen D..CJ ---
      datosOri = wsOri.Range("D4:CJ" & ultOri).Value                                                                              
                                                                                                                                
      ' --- 3) Loop principal ---                                                                                                 
      For i = 1 To UBound(datosOri, 1)
          dniVal = datosOri(i, cH)                                                                                                
          If IsError(dniVal) Then GoTo Sig                                                                                      
          dni = Trim(CStr(dniVal & ""))                                                                                           
          If Len(dni) = 0 Then GoTo Sig
          If Not IsNumeric(dni) Then GoTo Sig                                                                                     
                                                                                                                                  
          ' Filtro: CG (HDL) lleno O CJ (TRIG) lleno
          If LongStr_Dis(datosOri(i, cCG)) = 0 And LongStr_Dis(datosOri(i, cCJ)) = 0 Then                                         
              sinDislip = sinDislip + 1                                                                                           
              GoTo Sig
          End If                                                                                                                  
                                                                                                                                
          dniNorm = CStr(CDbl(dni))                                                                                               
          filaDes = 0                                                                                                           
          On Error Resume Next
          filaDes = mapaDes(dniNorm)
          On Error GoTo 0                                                                                                         
  
          If filaDes = 0 Then                                                                                                     
              ' Anexar nuevo DNI al final                                                                                       
              ultDes = ultDes + 1
              filaDes = ultDes
              wsDes.Cells(filaDes, "H").Value = CDbl(dni)                                                                         
              mapaDes.Add filaDes, dniNorm
              slotLibre = 1                                                                                                       
              nuevos = nuevos + 1                                                                                                 
          Else
              ' Buscar primer slot vacío de los 9: FECHA en cols 25, 40, 55, 70, 85, 100, 115, 130, 145                           
              slotLibre = 0                                                                                                       
              For n = 1 To 9
                  colFecha = 25 + (n - 1) * 15                                                                                    
                  cv = wsDes.Cells(filaDes, colFecha).Value                                                                       
                  If IsError(cv) Then cv = ""
                  If Len(Trim(CStr(cv & ""))) = 0 Then                                                                            
                      slotLibre = n                                                                                               
                      Exit For
                  End If                                                                                                          
              Next n                                                                                                            
              If slotLibre = 0 Then
                  yaLlenos = yaLlenos + 1
                  GoTo Sig                                                                                                        
              End If
          End If                                                                                                                  
                                                                                                                                
          colFecha = 25 + (slotLibre - 1) * 15
          wsDes.Cells(filaDes, colFecha).Value = datosOri(i, cD)        ' FECHA (offset 0)
          wsDes.Cells(filaDes, colFecha + 1).Value = datosOri(i, cCF)   ' COL TOTAL (+1)                                          
          wsDes.Cells(filaDes, colFecha + 2).Value = datosOri(i, cCG)   ' HDL       (+2)                                          
          wsDes.Cells(filaDes, colFecha + 3).Value = datosOri(i, cCH)   ' LDL       (+3)                                          
          wsDes.Cells(filaDes, colFecha + 4).Value = datosOri(i, cCI)   ' VLDL      (+4)                                          
          wsDes.Cells(filaDes, colFecha + 5).Value = datosOri(i, cCJ)   ' TRIG      (+5)                                          
          ' offsets +6 a +14 se dejan en blanco (la hoja tiene fórmulas ahí)                                                      
                                                                                                                                  
          transferidos = transferidos + 1                                                                                       
  Sig:                                                                                                                            
      Next i                                                                                                                    

  Fin:
      Application.EnableEvents = True
      Application.Calculation = xlCalculationAutomatic
      Application.ScreenUpdating = True                                                                                           
  
      MsgBox "Proceso finalizado en " & Format(Timer - t0, "0.0") & " seg." & vbCrLf & _                                          
             "Transferidos: " & transferidos & vbCrLf & _                                                                       
             "Nuevos DNIs anexados: " & nuevos & vbCrLf & _                                                                       
             "Sin dislipidemia (CG y CJ vacíos): " & sinDislip & vbCrLf & _                                                       
             "Sin espacio (9 slots llenos): " & yaLlenos, _
             vbInformation, "Dislipidemias"                                                                                       
  End Sub                                                                                                                       
                                                                                                                                  
  Private Function LongStr_Dis(v As Variant) As Long                                                                            
      If IsError(v) Then LongStr_Dis = 0: Exit Function
      If IsNull(v) Then LongStr_Dis = 0: Exit Function                                                                            
      LongStr_Dis = Len(Trim(CStr(v & "")))
  End Function                                                                                                                    
                                                                                                                                
  Private Function HojaPorNombre_Dis(wb As Workbook, nombre As String) As Worksheet                                               
      Dim ws As Worksheet                                                                                                       
      For Each ws In wb.Sheets                                                                                                    
          If UCase(Trim(ws.Name)) = UCase(Trim(nombre)) Then
              Set HojaPorNombre_Dis = ws: Exit Function                                                                           
          End If                                                                                                                  
      Next ws
  End Function  
