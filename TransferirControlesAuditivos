  Sub TransferirControlesAuditivos()
      Dim wsOri As Worksheet, wsDes As Worksheet
      Dim ultOri As Long, ultDes As Long
      Dim datosOri As Variant, dnisDes As Variant
      Dim mapaDes As Collection
      Dim i As Long, k As Long, n As Long
      Dim dni As String, dniNorm As String
      Dim filaDes As Long, colFecha As Long, controlLibre As Long
      Dim transferidos As Long, nuevos As Long, sinMed As Long, yaLlenos As Long
      Dim val As Variant, dniVal As Variant, cv As Variant
      Dim t0 As Double
                                                                                                                                  
      ' Índices dentro del array datosOri (rango lee desde D, así que D=1)
      Const cD As Long = 1     ' D - Fecha
      Const cH As Long = 5     ' H - DNI
      Const cAW As Long = 46   ' AW - 250 Hz OD
      Const cAZ As Long = 49   ' AZ - 2K OD
      Const cBA As Long = 50   ' BA - 3K OD
      Const cBB As Long = 51   ' BB - 4K OD
      Const cBE As Long = 54   ' BE - 250 Hz OI
      Const cBH As Long = 57   ' BH - 2K OI
      Const cBI As Long = 58   ' BI - 3K OI
      Const cBJ As Long = 59   ' BJ - 4K OI
                                                                                                                                  
      Set wsOri = HojaPorNombre_Aud(ThisWorkbook, "MATRIZ GENERAL")
      If wsOri Is Nothing Then Set wsOri = HojaPorNombre_Aud(ThisWorkbook, "REGISTRO MEDIWEB")
      Set wsDes = HojaPorNombre_Aud(ThisWorkbook, "CONS AUDITIVA")
      If wsOri Is Nothing Then MsgBox "Hoja origen no encontrada.", vbCritical: Exit Sub
      If wsDes Is Nothing Then MsgBox "CONS AUDITIVA no encontrada.", vbCritical: Exit Sub
                                                                                                                                  
      Application.ScreenUpdating = False
      Application.Calculation = xlCalculationManual
      Application.EnableEvents = False
      t0 = Timer

      ultOri = wsOri.Cells(wsOri.Rows.Count, "H").End(xlUp).Row
      ultDes = wsDes.Cells(wsDes.Rows.Count, "H").End(xlUp).Row
      If ultOri < 4 Then GoTo Fin
      If ultDes < 3 Then ultDes = 3
                                                                                                                                  
      ' --- 1) Mapa DNI -> fila en CONS AUDITIVA (lectura masiva) ---
      Set mapaDes = New Collection
      If ultDes >= 4 Then
          ' Leemos desde H3 (incluye encabezado) para garantizar al menos 2 celdas ? siempre array
          dnisDes = wsDes.Range("H3:H" & ultDes).Value
          For k = 2 To UBound(dnisDes, 1)   ' k=1 es la fila 3 (header), la saltamos
              val = dnisDes(k, 1)
              If Not IsError(val) Then
                  If IsNumeric(val) And Len(Trim(CStr(val & ""))) > 0 Then
                      On Error Resume Next
                      mapaDes.Add k + 2, CStr(CDbl(val))   ' fila real = k + 2 (k=2 ? fila 4)
                      On Error GoTo 0
                  End If
              End If
          Next k
      End If

      ' --- 2) Bulk read origen (D..BJ) en una sola operación ---
      datosOri = wsOri.Range("D4:BJ" & ultOri).Value
                                                                                                                                  
      ' --- 3) Loop principal en memoria ---
      For i = 1 To UBound(datosOri, 1)
          dniVal = datosOri(i, cH)
          If IsError(dniVal) Then GoTo Sig
          dni = Trim(CStr(dniVal & ""))
          If Len(dni) = 0 Then GoTo Sig
          If Not IsNumeric(dni) Then GoTo Sig
   
          ' Filtro: AW lleno O BE lleno
          If LongStr(datosOri(i, cAW)) = 0 And LongStr(datosOri(i, cBE)) = 0 Then
              sinMed = sinMed + 1
              GoTo Sig
          End If
                                                                                                                                
          dniNorm = CStr(CDbl(dni))
          filaDes = 0
          On Error Resume Next
          filaDes = mapaDes(dniNorm)
          On Error GoTo 0
                                                                                                                                  
          If filaDes = 0 Then
              ' Anexar nuevo DNI
              ultDes = ultDes + 1
              filaDes = ultDes
              wsDes.Cells(filaDes, "H").Value = CDbl(dni)
              mapaDes.Add filaDes, dniNorm
              controlLibre = 1
              nuevos = nuevos + 1
          Else
              ' Buscar primer slot vacío (max 7 lecturas)
              controlLibre = 0
              For n = 1 To 7
                  colFecha = 38 + (n - 1) * 13
                  cv = wsDes.Cells(filaDes, colFecha).Value
                  If IsError(cv) Then cv = ""
                  If Len(Trim(CStr(cv & ""))) = 0 Then
                      controlLibre = n
                      Exit For
                  End If
              Next n
              If controlLibre = 0 Then
                  yaLlenos = yaLlenos + 1
                  GoTo Sig
              End If
          End If
   
          colFecha = 38 + (controlLibre - 1) * 13
          wsDes.Cells(filaDes, colFecha).Value = datosOri(i, cD)
          wsDes.Cells(filaDes, colFecha + 1).Value = datosOri(i, cAZ)
          wsDes.Cells(filaDes, colFecha + 2).Value = datosOri(i, cBA)
          wsDes.Cells(filaDes, colFecha + 3).Value = datosOri(i, cBB)
          wsDes.Cells(filaDes, colFecha + 5).Value = datosOri(i, cBH)
          wsDes.Cells(filaDes, colFecha + 6).Value = datosOri(i, cBI)
          wsDes.Cells(filaDes, colFecha + 7).Value = datosOri(i, cBJ)
                                                                                                                                  
          transferidos = transferidos + 1
Sig:
      Next i
                                                                                                                                  
Fin:
      Application.EnableEvents = True
      Application.Calculation = xlCalculationAutomatic
      Application.ScreenUpdating = True

      MsgBox "Proceso finalizado en " & Format(Timer - t0, "0.0") & " seg." & vbCrLf & _
             "Transferidos: " & transferidos & vbCrLf & _
             "Nuevos DNIs anexados: " & nuevos & vbCrLf & _
             "Sin mediciones (AW y BE vacíos): " & sinMed & vbCrLf & _
             "Sin espacio (7 controles llenos): " & yaLlenos, _
             vbInformation, "Controles Auditivos"
  End Sub
                                                                                                                                
  Private Function LongStr(v As Variant) As Long
      If IsError(v) Then LongStr = 0: Exit Function
      If IsNull(v) Then LongStr = 0: Exit Function
      LongStr = Len(Trim(CStr(v & "")))
  End Function
                                                                                                                                  
  Private Function HojaPorNombre_Aud(wb As Workbook, nombre As String) As Worksheet
      Dim ws As Worksheet
      For Each ws In wb.Sheets
          If UCase(Trim(ws.Name)) = UCase(Trim(nombre)) Then
              Set HojaPorNombre_Aud = ws: Exit Function
          End If
      Next ws
  End Function


